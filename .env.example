# ── TrendScanner AI — environment template ────────────────────────────────────
# Copy this file to .env and fill in your actual keys.
# The .env file is git-ignored and never baked into the Docker image.

# Required for AI summary tab (Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: live INR price hints via Google Shopping
SERPAPI_API_KEY=your_serpapi_key_here

# Optional: USD → INR conversion rate (default 83.0)
USD_TO_INR_RATE=83.0

# ── Email reports (Export tab → Send report) ─────────────────────────────────
#
# RECOMMENDED — Brevo (reliable inbox delivery, free tier ~300 emails/day):
#   1. Sign up at https://www.brevo.com
#   2. Senders & IP → Senders → Add sender → verify your Gmail (click link in inbox)
#   3. SMTP & API → Generate API key (xkeysib-...)
#   4. Set below and restart the app
EMAIL_PROVIDER=brevo
BREVO_API_KEY=your_brevo_api_key_here
SMTP_FROM=your.verified@gmail.com
SMTP_FROM_NAME=TrendScanner AI
#
# FALLBACK — Gmail SMTP (easy but often goes to spam):
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your.email@gmail.com
# SMTP_PASSWORD=your_gmail_app_password_here
# SMTP_FROM=your.email@gmail.com
# SMTP_FROM_NAME=TrendScanner AI
# SMTP_USE_TLS=true
